-- The result must have number of transactions more than 10 and total spend more than 1000 on those transaction by corresponding
-- customer

SELECT CustomerID, COUNT(*) AS NumberOfTransactions, 
round(SUM(Price * QuantityPurchased)) AS TotalSpent 
FROM sales_transaction
GROUP BY CustomerID HAVING NumberOfTransactions > 10 AND TotalSpent > 1000 
ORDER BY TotalSpent DESC; 


-- Occasional customers- Low Purchase Frequency

-- the result table must have number of transaction less than or equal to 2 and corresponding total amount spent on those 
-- transactions by related customers 

SELECT CustomerID, COUNT(*) AS NumberOfTransactions, SUM(Price * QuantityPurchased) AS TotalSpent 
FROM sales_transaction
GROUP BY CustomerID HAVING NumberOfTransactions <= 2 -- Customers with 2 or fewer transactions 
ORDER BY NumberOfTransactions ASC, TotalSpent DESC; 


/*
Write a SQL query that describes the total number of purchases made by each customer against each 
productID to understand the repeat customers in the company. */

SELECT CustomerID, ProductID, COUNT(*) AS TimesPurchased 
FROM sales_transaction
GROUP BY CustomerID, ProductID HAVING TimesPurchased > 1 
ORDER BY TimesPurchased DESC, CustomerID; 


-- Loyality Indicators

-- Duration between the first and the last purchase as an indicator

-- The result table must have the first date of purchase , the last date of purchage and the difference between the first
-- and last date 
/*
A useful loyalty indicator could include :
> Number of purchases
> Average days between purchases
> recency (how recently they purchased)
> Duration of relation (Firt to last purchase span)


*/

With Purchase_Summary as(
select 
CustomerID, 
count(*) As TotalPurchases,
max(TransactionDate_updated) as lastpurchase, min(TransactionDate_updated) as firstpurchase,
datediff(max(TransactionDate_updated),min(TransactionDate_updated)) as DaysBetweenFirstAndLast, 
Datediff('2023-07-30',max(TransactionDate_updated)) as DaysSinceLastPurchase
from sales_transaction
group by CustomerID
order by TotalPurchases desc, DaysBetweenFirstAndLast desc
),

Loyalty_Score AS (
select *,
Round(DaysBetweenFirstAndLast/NullIF(TotalPurchases,0),1) As AvgDaysBetweenPurchases
from Purchase_Summary
)

select 
CustomerID,
TotalPurchases,
firstpurchase,
lastpurchase,
DaysBetweenFirstAndLast,
DaysSinceLastPurchase,
AvgDaysBetweenPurchases,
Case 
	when totalpurchases >=10 and DaysSinceLastPurchase<=30 Then 'High Loyalty'
    when totalpurchases >=5 and DaysSinceLastPurchase<=60 Then 'Moderate Loyalty' 
	Else 'Low Loyalty'
End as LoyaltyTier
from Loyalty_Score
order by LoyaltyTier, AvgDaysBetweenPurchases;


