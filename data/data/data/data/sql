# Identify and Fix Incorrect Prices in Sales Transactions

/*First, identify discrepancies between sales_transactions.PricePerPiece and product_inventory.PricePerPiece for the same ProductID. */

select 
st.*,
pi.Productid,
pi.price as InventoryPrice
from sales_transaction st
join product_inventory pi on st.productid = pi.productid
where st.price <> pi.price;


#  update the sales transactions to match the inventory prices where discrepancies are found


Update sales_transaction st
set Price = (
select pi.price 
from product_inventory pi 
where st.priductid = pi.producctid)
where st.productid in (
select productid from product_inventory where st.price <> product_inventory.price);


-- the above query as 2 correlated subqueires which execute row by row
-- first the subquery in the where clause executes and gives the list of product the have a problem
-- next the subquery to update the price executes along with update


Update sales_transaction st
join product_inventory pi on st.productid = pi.productid
set st.price = pi.price
where st.price <> pi.price;

